# ─── LLM ──────────────────────────────────────────────────────────────────────
# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# Anthropic API key (required when MODEL_PROVIDER=anthropic or any agent uses anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Mistral API key (required when MODEL_PROVIDER=mistral or any agent uses mistral)
# MISTRAL_API_KEY=...

# Global model fallback — used by every agent unless overridden per-agent below.
# MODEL_PROVIDER=openai
# MODEL_NAME=gpt-4o-mini

# Optional: override the sampling temperature
# OPENAI_TEMPERATURE=0.0

# Deprecated: use MODEL_NAME instead (kept for backwards compatibility)
# OPENAI_MODEL=gpt-4o-mini

# ─── Neo4j (Knowledge Graph agent) ────────────────────────────────────────────
# Change to a strong, unique password before deploying
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pangia-password

# ─── GraphDB / SPARQL (RDF agent) ─────────────────────────────────────────────
# Repository name to use in GraphDB (created on first run if missing)
GRAPHDB_REPOSITORY=pangia

# ─── ChromaDB (Vector agent) ──────────────────────────────────────────────────
# Host/port are auto-configured inside Docker; override for external instances.
# CHROMA_HOST=localhost
# CHROMA_PORT=8001

# ─── PostGIS (Spatial SQL agent) ──────────────────────────────────────────────
# Change to strong, unique credentials before deploying
POSTGIS_USER=pangia
POSTGIS_PASSWORD=pangia-password
POSTGIS_DB=pangia

# ─── Redis (sessions) ─────────────────────────────────────────────────────────
# Automatically set to redis://redis:6379 inside Docker.
# Override only when running the backend locally without Docker.
# REDIS_URL=redis://localhost:6379
# SESSION_TTL_SECONDS=3600

# ─── MCP connectors ───────────────────────────────────────────────────────────
# data.gouv.fr MCP endpoint (default points to the public instance)
# DATA_GOUV_MCP_URL=https://mcp.data.gouv.fr/mcp

# GeoNetwork MCP endpoint URLs are declared per-instance in source_registry.yml
# (see backend/config/source_registry.yml — mcp_url field on each entry).

# ─── Seeding (dev / demo mode) ────────────────────────────────────────────────
# Set to true to populate databases with sample data on startup.
# Set to false (or leave unset) in production to skip seeding.
# SEED_DB=true

# Theme to load when SEED_DB=true.
# Built-in themes: dinosaurs, pandemic
# Add custom themes by creating app/db/themes/<name>.py
# SEED_THEME=pandemic

# ─── Agent enable / disable ───────────────────────────────────────────────────
# The Orchestrator is always active.
# Set any flag below to false to fully disable that sub-agent.
# Disabled agents are excluded from routing and hidden in the frontend UI.
#
# Connector agents (parallel, routed by intent):
# NEO4J_AGENT_ENABLED=true
# RDF_AGENT_ENABLED=true
# VECTOR_CHROMA_AGENT_ENABLED=true
# POSTGIS_AGENT_ENABLED=true
# DATAGOUV_MCP_AGENT_ENABLED=true
# GEONETWORKMCP_AGENT_ENABLED=true
# GEO_AGENT_ENABLED=true
#
# Post-processing agents (sequential, gated independently):
# MAPVIZ_AGENT_ENABLED=true
# DATAVIZ_AGENT_ENABLED=true
# HUMANOUTPUT_AGENT_ENABLED=true
#
# Pipeline stages:
# INTENT_PARSER_ENABLED=true
# SMART_DISPATCHER_ENABLED=true

# ─── ReAct loop iterations ────────────────────────────────────────────────────
# Global maximum number of LLM+tool iterations per agent (one call + tool use).
# Lower to reduce latency/cost; raise for complex multi-step tasks.
# AGENT_MAX_ITERATIONS=10
#
# Per-agent overrides — set to 0 to inherit the global value above.
# NEO4J_AGENT_MAX_ITERATIONS=0
# RDF_AGENT_MAX_ITERATIONS=0
# VECTOR_CHROMA_AGENT_MAX_ITERATIONS=0
# POSTGIS_AGENT_MAX_ITERATIONS=0
# MAPVIZ_AGENT_MAX_ITERATIONS=0
# DATAGOUV_MCP_AGENT_MAX_ITERATIONS=0
# GEONETWORK_MCP_AGENT_MAX_ITERATIONS=0
# DATAVIZ_AGENT_MAX_ITERATIONS=0
# GEO_AGENT_MAX_ITERATIONS=0
# HUMANOUTPUT_AGENT_MAX_ITERATIONS=0
# INTENT_PARSER_AGENT_MAX_ITERATIONS=0
# SMART_DISPATCHER_AGENT_MAX_ITERATIONS=0
#
# Geo sub-agents:
# GEO_ADDRESS_AGENT_MAX_ITERATIONS=0
# GEO_SPATIAL_PARSER_AGENT_MAX_ITERATIONS=0
# GEO_DISTANCE_AGENT_MAX_ITERATIONS=0
# GEO_BUFFER_AGENT_MAX_ITERATIONS=0
# GEO_ISOCHRONE_AGENT_MAX_ITERATIONS=0
# GEO_PROXIMITY_AGENT_MAX_ITERATIONS=0
# GEO_INTERSECTION_AGENT_MAX_ITERATIONS=0
# GEO_AREA_AGENT_MAX_ITERATIONS=0
# GEO_HOTSPOT_AGENT_MAX_ITERATIONS=0
# GEO_SHORTEST_PATH_AGENT_MAX_ITERATIONS=0
# GEO_ELEVATION_AGENT_MAX_ITERATIONS=0
# GEO_GEOMETRY_OPS_AGENT_MAX_ITERATIONS=0
# GEO_TEMPORAL_AGENT_MAX_ITERATIONS=0
# GEO_VIEWSHED_AGENT_MAX_ITERATIONS=0

# ─── Per-agent model configuration ────────────────────────────────────────────
# Each agent can use a different LLM provider and model.
# Set <AGENT>_MODEL_PROVIDER and <AGENT>_MODEL_NAME to override the defaults.
# Supported providers: openai (default), anthropic (requires langchain-anthropic),
#                      ollama (requires langchain-ollama).
# Leave empty to fall back to the global MODEL_PROVIDER / MODEL_NAME above.
#
# Pipeline stages:
# ROUTER_MODEL_PROVIDER=openai
# ROUTER_MODEL_NAME=gpt-4o-mini
# INTENT_PARSER_AGENT_MODEL_PROVIDER=openai
# INTENT_PARSER_AGENT_MODEL_NAME=gpt-4o-mini
# SMART_DISPATCHER_AGENT_MODEL_PROVIDER=openai
# SMART_DISPATCHER_AGENT_MODEL_NAME=gpt-4o-mini
#
# Connector agents:
# NEO4J_AGENT_MODEL_PROVIDER=openai
# NEO4J_AGENT_MODEL_NAME=gpt-4o-mini
# RDF_AGENT_MODEL_PROVIDER=openai
# RDF_AGENT_MODEL_NAME=gpt-4o-mini
# VECTOR_CHROMA_AGENT_MODEL_PROVIDER=openai
# VECTOR_CHROMA_AGENT_MODEL_NAME=gpt-4o-mini
# POSTGIS_AGENT_MODEL_PROVIDER=openai
# POSTGIS_AGENT_MODEL_NAME=gpt-4o-mini
# DATAGOUV_MCP_AGENT_MODEL_PROVIDER=openai
# DATAGOUV_MCP_AGENT_MODEL_NAME=gpt-4o-mini
# GEONETWORK_MCP_AGENT_MODEL_PROVIDER=openai
# GEONETWORK_MCP_AGENT_MODEL_NAME=gpt-4o-mini
#
# Post-processing agents:
# MAPVIZ_AGENT_MODEL_PROVIDER=openai
# MAPVIZ_AGENT_MODEL_NAME=gpt-4o-mini
# DATAVIZ_AGENT_MODEL_PROVIDER=openai
# DATAVIZ_AGENT_MODEL_NAME=gpt-4o-mini
# HUMANOUTPUT_AGENT_MODEL_PROVIDER=openai
# HUMANOUTPUT_AGENT_MODEL_NAME=gpt-4o-mini
# MERGE_MODEL_PROVIDER=openai
# MERGE_MODEL_NAME=gpt-4o-mini
#
# Geospatial orchestrator and sub-agents:
# GEO_AGENT_MODEL_PROVIDER=openai
# GEO_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_ADDRESS_AGENT_MODEL_PROVIDER=openai
# GEO_ADDRESS_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_SPATIAL_PARSER_AGENT_MODEL_PROVIDER=openai
# GEO_SPATIAL_PARSER_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_DISTANCE_AGENT_MODEL_PROVIDER=openai
# GEO_DISTANCE_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_BUFFER_AGENT_MODEL_PROVIDER=openai
# GEO_BUFFER_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_ISOCHRONE_AGENT_MODEL_PROVIDER=openai
# GEO_ISOCHRONE_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_PROXIMITY_AGENT_MODEL_PROVIDER=openai
# GEO_PROXIMITY_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_INTERSECTION_AGENT_MODEL_PROVIDER=openai
# GEO_INTERSECTION_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_AREA_AGENT_MODEL_PROVIDER=openai
# GEO_AREA_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_HOTSPOT_AGENT_MODEL_PROVIDER=openai
# GEO_HOTSPOT_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_SHORTEST_PATH_AGENT_MODEL_PROVIDER=openai
# GEO_SHORTEST_PATH_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_ELEVATION_AGENT_MODEL_PROVIDER=openai
# GEO_ELEVATION_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_GEOMETRY_OPS_AGENT_MODEL_PROVIDER=openai
# GEO_GEOMETRY_OPS_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_TEMPORAL_AGENT_MODEL_PROVIDER=openai
# GEO_TEMPORAL_AGENT_MODEL_NAME=gpt-4o-mini
# GEO_VIEWSHED_AGENT_MODEL_PROVIDER=openai
# GEO_VIEWSHED_AGENT_MODEL_NAME=gpt-4o-mini

# ─── Arize Phoenix (agent observability) ──────────────────────────────────────
# Phoenix UI is available at http://localhost:6006 once the stack is running.
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
# PHOENIX_PROJECT_NAME=pangia-geoia

# ─── Ollama (local LLM server) ────────────────────────────────────────────────
# Ollama runs as a Docker service on port 11434.
# OLLAMA_BASE_URL is automatically set to http://ollama:11434 inside Docker.
# Override only when running Ollama outside of the Compose stack.
# OLLAMA_BASE_URL=http://localhost:11434
#
# To use a local Ollama model for any agent, set its MODEL_PROVIDER / MODEL_NAME:
#   NEO4J_AGENT_MODEL_PROVIDER=ollama
#   NEO4J_AGENT_MODEL_NAME=gemma4
#
# See docs/ollama-gemma4-setup.md for instructions on pulling the gemma4 model.

# ─── Backend V2 – PostgreSQL + pgvector ───────────────────────────────────────
# Dedicated PostgreSQL instance for the second-generation backend.
# Stores audit logs (with hash chain) and long-term memory (pgvector embeddings).
# POSTGRES2_USER=pangia2
# POSTGRES2_PASSWORD=pangia2-password
# POSTGRES2_DB=pangia2

# ─── Backend V2 – Human-in-the-Loop (HITL) ────────────────────────────────────
# Ambiguity detection threshold (0 = never trigger, 1 = always trigger).
# HITL_AMBIGUITY_THRESHOLD=0.7
# Maximum seconds the backend waits for a human response before timing out.
# HITL_TIMEOUT_SECONDS=120
