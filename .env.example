# ─── LLM ──────────────────────────────────────────────────────────────────────
# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: override the default model (gpt-4o-mini)
# OPENAI_MODEL=gpt-4o

# ─── Neo4j (Knowledge Graph agent) ────────────────────────────────────────────
# Change to a strong, unique password before deploying
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pangia-password

# ─── GraphDB / SPARQL (RDF agent) ─────────────────────────────────────────────
# Repository name to use in GraphDB (created on first run if missing)
GRAPHDB_REPOSITORY=pangia

# ─── ChromaDB (Vector agent) ──────────────────────────────────────────────────
# Host/port are auto-configured inside Docker; override for external instances.
# CHROMA_HOST=localhost
# CHROMA_PORT=8001

# ─── PostGIS (Spatial SQL agent) ──────────────────────────────────────────────
# Change to strong, unique credentials before deploying
POSTGIS_USER=pangia
POSTGIS_PASSWORD=pangia-password
POSTGIS_DB=pangia

# ─── Redis (sessions) ─────────────────────────────────────────────────────────
# Automatically set to redis://redis:6379 inside Docker.
# Override only when running the backend locally without Docker.
# REDIS_URL=redis://localhost:6379

# ─── Seeding (dev / demo mode) ────────────────────────────────────────────────
# Set to true to populate databases with sample data on startup.
# Set to false (or leave unset) in production to skip seeding.
# SEED_DB=true

# Theme to load when SEED_DB=true.
# Built-in themes: pandemic
# Add custom themes by creating app/db/themes/<name>.py
# SEED_THEME=pandemic

# ─── Agent enable / disable ───────────────────────────────────────────────────
# The master orchestrator is always active.
# Set any of the flags below to false to fully disable that sub-agent.
# Disabled agents are excluded from routing and hidden in the frontend UI.
# NEO4J_AGENT_ENABLED=true
# RDF_AGENT_ENABLED=true
# VECTOR_AGENT_ENABLED=true
# POSTGIS_AGENT_ENABLED=true
# MAP_AGENT_ENABLED=true

# ─── Per-agent model configuration ────────────────────────────────────────────
# Each agent can use a different LLM provider and model.
# Set <AGENT>_MODEL_PROVIDER and <AGENT>_MODEL_NAME to override the defaults.
# Supported providers: openai (default), anthropic (requires langchain-anthropic),
#                      ollama (requires langchain-ollama).
# Leave empty to fall back to the global OPENAI_MODEL / OPENAI_API_KEY above.
#
# Router (decides which sub-agents to call):
# ROUTER_MODEL_PROVIDER=openai
# ROUTER_MODEL_NAME=gpt-4o-mini
#
# Neo4j Knowledge Graph agent:
# NEO4J_AGENT_MODEL_PROVIDER=openai
# NEO4J_AGENT_MODEL_NAME=gpt-4o-mini
#
# RDF / SPARQL agent:
# RDF_AGENT_MODEL_PROVIDER=openai
# RDF_AGENT_MODEL_NAME=gpt-4o-mini
#
# Vector Search agent:
# VECTOR_AGENT_MODEL_PROVIDER=openai
# VECTOR_AGENT_MODEL_NAME=gpt-4o-mini
#
# PostGIS Spatial SQL agent:
# POSTGIS_AGENT_MODEL_PROVIDER=openai
# POSTGIS_AGENT_MODEL_NAME=gpt-4o-mini
#
# Map / GeoJSON extraction agent:
# MAP_AGENT_MODEL_PROVIDER=openai
# MAP_AGENT_MODEL_NAME=gpt-4o-mini
#
# data.gouv.fr Open Data agent:
# DATA_GOUV_AGENT_MODEL_PROVIDER=openai
# DATA_GOUV_AGENT_MODEL_NAME=gpt-4o-mini
#
# Merge / synthesis node:
# MERGE_MODEL_PROVIDER=openai
# MERGE_MODEL_NAME=gpt-4o-mini

# ─── Arize Phoenix (agent observability) ──────────────────────────────────────
# Phoenix UI is available at http://localhost:6006 once the stack is running.
# Override the project name to organise traces in the Phoenix UI.
# PHOENIX_PROJECT_NAME=pangia-geoia
